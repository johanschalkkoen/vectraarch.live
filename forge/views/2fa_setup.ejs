<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Forge | Secure Protocol</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Mono:wght@300;400;500&family=Barlow:wght@300;400&family=Barlow+Condensed:wght@300;400;500;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/shared/forge.css">
</head>
<body>

    <div class="grid-bg"></div>

    <nav>
        <a href="https://vectraarch.live" class="nav-logo">Vectra<span>&nbsp;</span>Arch</a>
        <div class="nav-right">Forge · 2FA Setup</div>
    </nav>

    <div class="wrap">
        <div class="top-bar"></div>
        <div class="card">
            <div class="card-header">
                <div class="eyebrow">§ Vectra Arch · Forge · Security Protocol</div>
                <div class="card-title">Init 2FA</div>
                <div class="card-sub">Scan QR with your authenticator app</div>
            </div>
            <div class="card-body">
                <div class="qr-frame">
                    <img src="<%= qr %>" alt="QR Protocol">
                </div>
                <div class="secret-key">KEY: <%= secret %></div>
                <form action="/forge/auth/2fa/setup" method="POST" style="display:contents;">
                    <div class="field-group">
                        <label class="field-label" for="token">Verification Code</label>
                        <input class="field-input" id="token" type="text" name="token" placeholder="000000" maxlength="6" required autofocus autocomplete="off">
                    </div>
                    <button type="submit" class="btn-primary">Link Device ↗</button>
                </form>
            </div>
            <div class="card-footer">
                <a href="/" class="footer-link">← Cancel</a>
                <div class="status-dot"></div>
            </div>
        </div>
    </div>

</body>
</html>
