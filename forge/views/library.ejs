<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Book Forge | Hub</title>
    <link rel="stylesheet" href="/forge/public/style.css">
</head>
<body>

    <div class="grid-bg"></div>

    <div class="container">

        <!-- ── HEADER ── -->
        <header class="app-header">
            <h1>BOOK FORGE <span style="color:var(--text-dim); font-size:1.3rem;">// HUB</span></h1>
            <nav style="display:flex; gap:8px; align-items:center;">
                <% if (is2FAEnabled) { %>
                    <span style="font-family:'DM Mono',monospace; font-size:0.55rem; letter-spacing:0.18em; text-transform:uppercase; color:var(--accent2); border:1px solid var(--border2); padding:0 12px; height:34px; display:inline-flex; align-items:center; gap:8px;">
                        <span style="width:5px;height:5px;border-radius:50%;background:var(--accent);box-shadow:0 0 5px var(--accent);flex-shrink:0;"></span>
                        Resonance Secured
                    </span>
                <% } else { %>
                    <a href="/forge/auth/2fa/setup" style="font-family:'DM Mono',monospace;font-size:0.55rem;letter-spacing:0.18em;text-transform:uppercase;color:#d4a800;border:1px solid #d4a800;padding:0 12px;height:34px;display:inline-flex;align-items:center;gap:8px;text-decoration:none;transition:background 0.2s;" onmouseover="this.style.background='rgba(212,168,0,0.08)'" onmouseout="this.style.background='transparent'">
                        <span style="width:5px;height:5px;border-radius:50%;background:#d4a800;flex-shrink:0;"></span>
                        Resonance Unsecured
                    </a>
                <% } %>
                <a href="#" onclick="document.getElementById('forge-contact-overlay').classList.add('open');return false;" class="nav-item-btn" style="min-width:80px;" onmouseover="this.style.background='rgba(0,255,65,0.08)'" onmouseout="this.style.background='transparent'">Contact</a>
                <a href="/forge/logout" class="nav-item-btn" style="min-width:80px;color:var(--red);border-color:var(--red);" onmouseover="this.style.background='rgba(184,64,64,0.08)'" onmouseout="this.style.background='transparent'">Logout</a>
            </nav>
        </header>

        <!-- ── FORGE NEW VOLUME BAR ── -->
        <div style="flex:0 0 auto;padding:14px 32px;border-bottom:1px solid var(--border);background:var(--bg2);display:flex;align-items:center;gap:16px;position:relative;z-index:5;">
            <span class="section-label" style="white-space:nowrap;">§ Forge Volume</span>
            <form action="/forge/create-book" method="POST" enctype="multipart/form-data" style="display:flex;gap:8px;flex:1;align-items:center;">
                <input type="text" name="bookName" placeholder="VOLUME TITLE" required style="flex:2;margin:0;height:34px;padding:0 14px;">
                <input type="text" name="coverUrl" placeholder="COVER URL" style="flex:1.5;margin:0;height:34px;padding:0 14px;">
                <input type="file" name="coverFile" style="flex:1;margin:0;font-size:0.55rem;border:1px solid var(--border2);padding:0 10px;height:34px;background:var(--input-bg);color:var(--text-dim);font-family:'DM Mono',monospace;">
                <button type="submit" class="btn-primary" style="min-width:90px;height:34px;flex-shrink:0;">Forge ↗</button>
            </form>
        </div>

        <!-- ── BOOK GRID ── -->
        <div style="flex:1;overflow-y:auto;padding:32px;position:relative;z-index:1;">

            <%
                const ROMAN = ['I','II','III','IV','V','VI','VII','VIII','IX','X',
                               'XI','XII','XIII','XIV','XV','XVI','XVII','XVIII','XIX','XX'];
                const GRADIENTS = [
                    'linear-gradient(160deg,#0a1a0a 0%,#001a08 60%,#002210 100%)',
                    'linear-gradient(135deg,#080d12 0%,#0a1520 60%,#061018 100%)',
                    'linear-gradient(150deg,#12080a 0%,#1a0808 60%,#100005 100%)',
                    'linear-gradient(140deg,#0d0d08 0%,#181508 60%,#120f00 100%)',
                    'linear-gradient(160deg,#080a12 0%,#06091a 60%,#030718 100%)',
                    'linear-gradient(130deg,#0a0a0a 0%,#141414 60%,#0d0d0d 100%)',
                    'linear-gradient(155deg,#080f0a 0%,#0a1a0d 60%,#051208 100%)',
                    'linear-gradient(145deg,#0f0808 0%,#1a0a08 60%,#120500 100%)',
                ];
            %>

            <div class="book-grid">
                <% books.forEach((book, idx) => { %>
                    <div class="book-card" id="book-<%= book.id %>">

                        <!-- COVER -->
                        <a href="/forge/book/<%= book.id %>" style="text-decoration:none;color:inherit;display:block;">
                            <div class="cover-art" style="background:<%= GRADIENTS[idx % 8] %>;">
                                <div class="cover-grid-lines"></div>
                                <img src="<%= book.cover_url %>" onerror="this.style.display='none'" alt="<%= book.title %>">
                                <div class="cover-corner"><%= ROMAN[idx] || (idx+1) %></div>
                                <div class="cover-accent-line"></div>
                                <% if (book.published) { %>
                                    <div class="cover-published-badge">Published</div>
                                <% } %>
                            </div>
                        </a>

                        <!-- TITLE BELOW COVER -->
                        <div class="book-info">
                            <div class="book-info-title"><%= book.title %></div>
                        </div>

                        <!-- CONTROLS -->
                        <div class="card-controls">
                            <button onclick="toggleEditBook('<%= book.id %>')">Edit</button>
                            <button onclick="toggleEditCover('<%= book.id %>')" style="border-color:var(--border);color:var(--text-dim);">Cover</button>
                            <% if (book.owner_type === 'Google') { %>
                                <svg style="width:14px;height:14px;flex-shrink:0;" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.1c-.22-.66-.35-1.36-.35-2.1s.13-1.44.35-2.1V7.06H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.94l3.66-2.84z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.06l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
                            <% } else { %>
                                <img src="/favicon-32x32.png" style="width:14px;height:14px;flex-shrink:0;" alt="">
                            <% } %>
                            <button onclick="promptDelete('del-book-<%= book.id %>')" class="btn-danger">Purge</button>
                        </div>

                        <!-- PUBLISH ROW -->
                        <div class="publish-row">
                            <% if (book.published) { %>
                                <button id="pub-btn-<%= book.id %>"
                                    onclick="togglePublish('<%= book.id %>', false)"
                                    style="flex:1;height:26px;min-width:0;font-size:0.48rem;letter-spacing:0.12em;color:var(--accent2);border-color:var(--accent2);background:rgba(0,179,44,0.06);">
                                    ✓ Published
                                </button>
                                <button onclick="togglePublish('<%= book.id %>', false)"
                                    style="height:26px;min-width:0;padding:0 10px;font-size:0.45rem;letter-spacing:0.1em;color:var(--text-dim);border-color:var(--border);">
                                    Unpublish
                                </button>
                            <% } else { %>
                                <button id="pub-btn-<%= book.id %>"
                                    onclick="togglePublish('<%= book.id %>', true)"
                                    style="flex:1;height:26px;min-width:0;font-size:0.48rem;letter-spacing:0.12em;color:var(--text-dim);border-color:var(--border);">
                                    Publish to Press ↗
                                </button>
                            <% } %>
                        </div>

                        <!-- EXPORT ROW -->
                        <div style="padding:6px 10px;border-top:1px solid var(--border);background:rgba(0,0,0,0.25);display:flex;gap:4px;align-items:center;flex-wrap:wrap;">
                            <span style="font-family:'DM Mono',monospace;font-size:0.42rem;letter-spacing:0.18em;text-transform:uppercase;color:var(--text-dim);margin-right:4px;white-space:nowrap;">Export:</span>
                            <a href="/forge/book/<%= book.id %>/export/docx" class="export-btn" title="Word Document">.docx</a>
                            <a href="/forge/book/<%= book.id %>/export/pdf"  class="export-btn" title="PDF">.pdf</a>
                            <a href="/forge/book/<%= book.id %>/export/epub" class="export-btn" title="EPUB e-reader">.epub</a>
                            <a href="/forge/book/<%= book.id %>/export/md"   class="export-btn" title="Markdown">.md</a>
                            <a href="/forge/book/<%= book.id %>/export/txt"  class="export-btn" title="Plain Text">.txt</a>
                        </div>

                        <!-- RENAME MASK -->
                        <div id="edit-<%= book.id %>" class="confirm-mask" style="border-color:var(--accent2);">
                            <form action="/forge/book/edit/<%= book.id %>" method="POST" style="width:100%;">
                                <p style="font-family:'DM Mono',monospace;font-size:0.55rem;letter-spacing:0.22em;text-transform:uppercase;color:var(--accent);margin-bottom:14px;">§ Rename Volume</p>
                                <input type="text" name="bookName" value="<%= book.title %>" required>
                                <div style="display:flex;gap:8px;">
                                    <button type="submit" class="btn-primary" style="flex:1;height:30px;min-width:0;">Update</button>
                                    <button type="button" onclick="toggleEditBook('<%= book.id %>')" style="flex:1;height:30px;min-width:0;">Cancel</button>
                                </div>
                            </form>
                        </div>

                        <!-- COVER MASK -->
                        <div id="cover-<%= book.id %>" class="confirm-mask" style="border-color:var(--border2);">
                            <form action="/forge/book/edit/<%= book.id %>" method="POST" enctype="multipart/form-data" style="width:100%;">
                                <p style="font-family:'DM Mono',monospace;font-size:0.55rem;letter-spacing:0.22em;text-transform:uppercase;color:var(--text-muted);margin-bottom:14px;">§ Reforge Cover</p>
                                <input type="hidden" name="bookName" value="<%= book.title %>">
                                <input type="text" name="coverUrl" placeholder="URL..." value="<%= book.cover_url %>">
                                <input type="file" name="coverFile">
                                <div style="display:flex;gap:8px;">
                                    <button type="submit" class="btn-primary" style="flex:1;height:30px;min-width:0;">Commit</button>
                                    <button type="button" onclick="toggleEditCover('<%= book.id %>')" style="flex:1;height:30px;min-width:0;">Abort</button>
                                </div>
                            </form>
                        </div>

                        <!-- DELETE MASK -->
                        <div id="del-book-<%= book.id %>" class="confirm-mask">
                            <p style="font-family:'DM Mono',monospace;font-size:0.55rem;letter-spacing:0.22em;text-transform:uppercase;color:var(--red);margin-bottom:14px;">Purge This Volume?</p>
                            <form action="/forge/book/delete/<%= book.id %>" method="POST" style="display:flex;gap:8px;">
                                <button type="submit" class="btn-danger" style="flex:1;height:30px;min-width:0;">Confirm</button>
                                <button type="button" onclick="cancelDelete('del-book-<%= book.id %>')" style="flex:1;height:30px;min-width:0;">Abort</button>
                            </form>
                        </div>
                    </div>
                <% }); %>
            </div>
        </div>

    </div>


    <!-- ── TOAST ── -->
    <div id="toast" style="display:none;position:fixed;bottom:24px;right:24px;z-index:9000;font-family:'DM Mono',monospace;font-size:0.6rem;letter-spacing:0.15em;text-transform:uppercase;padding:14px 20px;border:1px solid var(--accent2);background:var(--bg2);color:var(--accent2);max-width:380px;line-height:1.5;transition:opacity 0.3s;"></div>

    <script>
        // ── PUBLISH / UNPUBLISH ──────────────────────────────────────────
        async function togglePublish(bookId, publish) {
            const btn = document.getElementById('pub-btn-' + bookId);
            const origText = btn.textContent;
            btn.disabled = true;
            btn.textContent = publish ? 'Publishing…' : 'Unpublishing…';
            btn.style.opacity = '0.5';

            const endpoint = publish ? `/forge/book/${bookId}/publish` : `/forge/book/${bookId}/unpublish`;

            try {
                const r = await fetch(endpoint, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                });
                const data = await r.json();

                if (data.ok) {
                    // Reload the page so publish state reflects correctly
                    showToast(
                        publish
                            ? '✓ Published to vectraarch.live/press/'
                            : '✓ Unpublished from vectraarch.live/press/',
                        publish ? 'var(--accent2)' : 'var(--text-dim)'
                    );
                    setTimeout(() => location.reload(), 1200);
                } else {
                    showToast('✗ Error: ' + data.error, 'var(--red)');
                    btn.textContent = origText;
                    btn.style.opacity = '1';
                    btn.disabled = false;
                }
            } catch (e) {
                showToast('✗ Network error', 'var(--red)');
                btn.textContent = origText;
                btn.style.opacity = '1';
                btn.disabled = false;
            }
        }

        function showToast(msg, color) {
            const t = document.getElementById('toast');
            t.textContent = msg;
            t.style.borderColor = color;
            t.style.color = color;
            t.style.display = 'block';
            t.style.opacity = '1';
            setTimeout(() => {
                t.style.opacity = '0';
                setTimeout(() => t.style.display = 'none', 300);
            }, 5000);
        }

        // ── STANDARD HANDLERS ────────────────────────────────────────────
        function toggleEditBook(id) { const m = document.getElementById('edit-'+id); m.style.display = (m.style.display==='flex')?'none':'flex'; }
        function toggleEditCover(id) { const m = document.getElementById('cover-'+id); m.style.display = (m.style.display==='flex')?'none':'flex'; }
        function promptDelete(id) {
            const el = document.getElementById(id);
            if (!el) return;
            if (el.classList.contains('confirm-mask')) { el.style.display='flex'; return; }
            const mask = el.querySelector('.confirm-mask');
            if (mask) mask.style.display='flex';
        }
        function cancelDelete(id) {
            const el = document.getElementById(id);
            if (!el) return;
            if (el.classList.contains('confirm-mask')) { el.style.display='none'; return; }
            const mask = el.querySelector('.confirm-mask');
            if (mask) mask.style.display='none';
        }
        function toggleForgeResonance() {
            const c = document.getElementById('forge-res-content');
            const i = document.getElementById('forge-res-ind');
            const open = c.style.display==='block';
            c.style.display = open?'none':'block';
            i.innerText = open?'[+]':'[-]';
        }
    </script>

<style>
        .export-btn {
            font-family: 'DM Mono', monospace;
            font-size: 0.44rem;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: var(--text-dim);
            text-decoration: none;
            border: 1px solid var(--border);
            padding: 3px 8px;
            height: 22px;
            display: inline-flex;
            align-items: center;
            transition: border-color 0.2s, color 0.2s, background 0.2s;
            cursor: crosshair;
        }
        .export-btn:hover { border-color: var(--accent2); color: var(--accent2); background: rgba(0,179,44,0.05); }
    </style>

<!-- ── CONTACT OVERLAY ── -->
<div id="forge-contact-overlay" style="display:none;position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,0.85);backdrop-filter:blur(6px);align-items:center;justify-content:center;" onclick="if(event.target===this)this.classList.remove('open')">
  <div style="background:var(--bg2);border:1px solid var(--border2);padding:48px;max-width:520px;width:90%;position:relative;">
    <div style="font-family:'DM Mono',monospace;font-size:9px;letter-spacing:0.25em;text-transform:uppercase;color:var(--accent);margin-bottom:8px;">§ VectraArch · Forge · Contact</div>
    <div style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:28px;letter-spacing:0.06em;text-transform:uppercase;color:var(--text);margin-bottom:32px;">Get In Touch</div>
    <div id="forge-contact-msg" style="display:none;padding:12px 16px;margin-bottom:20px;font-family:'DM Mono',monospace;font-size:11px;letter-spacing:0.08em;"></div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px;">
      <div>
        <label style="font-family:'DM Mono',monospace;font-size:9px;letter-spacing:0.18em;text-transform:uppercase;color:var(--text-muted);display:block;margin-bottom:6px;">First Name <span style="color:var(--red)">*</span></label>
        <input id="fc-fname" type="text" style="width:100%;background:var(--bg3);border:1px solid var(--border2);color:var(--text);font-family:'DM Mono',monospace;font-size:13px;padding:10px 14px;outline:none;" placeholder="John"/>
      </div>
      <div>
        <label style="font-family:'DM Mono',monospace;font-size:9px;letter-spacing:0.18em;text-transform:uppercase;color:var(--text-muted);display:block;margin-bottom:6px;">Last Name <span style="color:var(--red)">*</span></label>
        <input id="fc-lname" type="text" style="width:100%;background:var(--bg3);border:1px solid var(--border2);color:var(--text);font-family:'DM Mono',monospace;font-size:13px;padding:10px 14px;outline:none;" placeholder="Doe"/>
      </div>
    </div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px;">
      <div>
        <label style="font-family:'DM Mono',monospace;font-size:9px;letter-spacing:0.18em;text-transform:uppercase;color:var(--text-muted);display:block;margin-bottom:6px;">Email <span style="color:var(--red)">*</span></label>
        <input id="fc-email" type="email" style="width:100%;background:var(--bg3);border:1px solid var(--border2);color:var(--text);font-family:'DM Mono',monospace;font-size:13px;padding:10px 14px;outline:none;" placeholder="john@example.com"/>
      </div>
      <div>
        <label style="font-family:'DM Mono',monospace;font-size:9px;letter-spacing:0.18em;text-transform:uppercase;color:var(--text-muted);display:block;margin-bottom:6px;">Phone <span style="color:var(--red)">*</span></label>
        <input id="fc-phone" type="tel" style="width:100%;background:var(--bg3);border:1px solid var(--border2);color:var(--text);font-family:'DM Mono',monospace;font-size:13px;padding:10px 14px;outline:none;" placeholder="+27 82 000 0000"/>
      </div>
    </div>
    <div style="margin-bottom:16px;">
      <label style="font-family:'DM Mono',monospace;font-size:9px;letter-spacing:0.18em;text-transform:uppercase;color:var(--text-muted);display:block;margin-bottom:6px;">Subject</label>
      <input id="fc-subject" type="text" style="width:100%;background:var(--bg3);border:1px solid var(--border2);color:var(--text);font-family:'DM Mono',monospace;font-size:13px;padding:10px 14px;outline:none;" placeholder="Forge enquiry"/>
    </div>
    <div style="margin-bottom:24px;">
      <label style="font-family:'DM Mono',monospace;font-size:9px;letter-spacing:0.18em;text-transform:uppercase;color:var(--text-muted);display:block;margin-bottom:6px;">Message</label>
      <textarea id="fc-message" rows="4" style="width:100%;background:var(--bg3);border:1px solid var(--border2);color:var(--text);font-family:'DM Mono',monospace;font-size:13px;padding:10px 14px;outline:none;resize:vertical;" placeholder="Your message..."></textarea>
    </div>
    <div style="display:flex;gap:12px;">
      <button onclick="submitForgeContact()" style="flex:1;background:var(--accent);color:#000;font-family:'DM Mono',monospace;font-size:11px;letter-spacing:0.18em;text-transform:uppercase;border:none;padding:14px;cursor:crosshair;font-weight:600;">Send Message ↗</button>
      <button onclick="document.getElementById('forge-contact-overlay').classList.remove('open')" style="background:transparent;border:1px solid var(--border2);color:var(--text-muted);font-family:'DM Mono',monospace;font-size:11px;letter-spacing:0.14em;text-transform:uppercase;padding:14px 20px;cursor:crosshair;">Close</button>
    </div>
  </div>
</div>
<style>
  #forge-contact-overlay { display: flex !important; opacity: 0; pointer-events: none; transition: opacity 0.2s; }
  #forge-contact-overlay.open { opacity: 1; pointer-events: all; }
</style>
<script>
async function submitForgeContact() {
  const msg = document.getElementById('forge-contact-msg');
  const payload = {
    fname:   document.getElementById('fc-fname').value.trim(),
    lname:   document.getElementById('fc-lname').value.trim(),
    email:   document.getElementById('fc-email').value.trim(),
    phone:   document.getElementById('fc-phone').value.trim(),
    subject: document.getElementById('fc-subject').value.trim(),
    message: document.getElementById('fc-message').value.trim(),
  };
  if (!payload.fname || !payload.lname || !payload.email || !payload.phone) {
    msg.style.display = 'block';
    msg.style.background = 'rgba(184,64,64,0.12)';
    msg.style.color = 'var(--red)';
    msg.textContent = '⚠ Please fill in all required fields.';
    return;
  }
  try {
    const r = await fetch('/api/forge', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) });
    const data = await r.json();
    msg.style.display = 'block';
    if (data.ok) {
      msg.style.background = 'rgba(0,255,65,0.08)';
      msg.style.color = 'var(--accent)';
      msg.textContent = '✓ Message sent. We will be in touch.';
      ['fc-fname','fc-lname','fc-email','fc-phone','fc-subject','fc-message'].forEach(id => document.getElementById(id).value = '');
    } else {
      msg.style.background = 'rgba(184,64,64,0.12)';
      msg.style.color = 'var(--red)';
      msg.textContent = '⚠ Failed to send. Please try again.';
    }
  } catch {
    msg.style.display = 'block';
    msg.style.background = 'rgba(184,64,64,0.12)';
    msg.style.color = 'var(--red)';
    msg.textContent = '⚠ Connection error. Please try again.';
  }
}
</script>
</body>
</html>
