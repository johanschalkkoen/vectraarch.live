<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Login · Book Forge · VectraArch</title>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Mono:ital,wght@0,300;0,400;0,500;1,300&family=Barlow:wght@300;400;500;600&family=Barlow+Condensed:wght@300;400;500;700;800&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="/shared/va.css"/>
  <link rel="stylesheet" href="/shared/auth.css"/>
</head>
<body>
<div class="grid-bg"></div>
<div class="accent-lines auth-accent-lines" aria-hidden="true">
  <svg viewBox="0 0 600 900" fill="none" preserveAspectRatio="xMaxYMid slice">
    <line x1="580" y1="0" x2="20" y2="900" stroke="rgba(212,160,23,0.07)" stroke-width="1"/>
    <line x1="540" y1="0" x2="0" y2="760" stroke="rgba(212,160,23,0.05)" stroke-width="0.5"/>
    <circle cx="540" cy="180" r="90" stroke="rgba(212,160,23,0.04)" stroke-width="0.5" fill="none"/>
    <circle cx="540" cy="180" r="130" stroke="rgba(212,160,23,0.025)" stroke-width="0.5" fill="none"/>
  </svg>
</div>

<div class="auth-wrap">
  <div class="auth-card">
    <div class="auth-eyebrow">§ Vectra Arch · Studio 08 · Book Forge</div>
    <div class="auth-title">Access</div>
    <div class="auth-sub">vectraarch.live/forge · Authorised Entry</div>

    <div class="auth-warning">
      <div class="auth-warning-dot"></div>
      <span class="auth-warning-text">Restricted · Authorised Personnel Only</span>
    </div>

    <% if (locals.error) { %>
    <div class="auth-error">⚠ <%= error %></div>
    <% } %>

    <form action="/forge/auth/manual" method="POST">
      <div class="auth-field">
        <label class="auth-label" for="cid">Username</label>
        <input class="auth-input" id="cid" name="cid" type="text"
               placeholder="username" autocomplete="username" required autofocus/>
      </div>
      <div class="auth-field">
        <label class="auth-label" for="ak">Key</label>
        <input class="auth-input" id="ak" name="ak" type="password"
               placeholder="········" autocomplete="current-password" required/>
      </div>
      <button class="auth-submit" type="submit">Enter ↗</button>
    </form>

    <div class="auth-divider"><span>or</span></div>

    <a href="/forge/auth/google" class="auth-google-btn">
      <svg style="width:16px;height:16px;flex-shrink:0;" viewBox="0 0 24 24">
        <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
        <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
        <path fill="#FBBC05" d="M5.84 14.1c-.22-.66-.35-1.36-.35-2.1s.13-1.44.35-2.1V7.06H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.94l3.66-2.84z"/>
        <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.06l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
      </svg>
      Continue with Google
    </a>

    <a href="https://vectraarch.live" class="auth-back">← Back to Vectra Arch</a>
  </div>
</div>
</body>
</html>
