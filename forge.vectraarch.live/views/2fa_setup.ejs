<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>2FA Setup · Book Forge · VectraArch</title>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Mono:ital,wght@0,300;0,400;0,500;1,300&family=Barlow:wght@300;400;500;600&family=Barlow+Condensed:wght@300;400;500;700;800&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="/forge.css"/>
</head>
<body>
<div class="grid-bg"></div>
<div class="accent-lines auth-accent-lines" aria-hidden="true">
  <svg viewBox="0 0 600 900" fill="none" preserveAspectRatio="xMaxYMid slice">
    <line x1="580" y1="0" x2="20" y2="900" stroke="rgba(212,160,23,0.07)" stroke-width="1"/>
    <line x1="540" y1="0" x2="0" y2="760" stroke="rgba(212,160,23,0.05)" stroke-width="0.5"/>
    <circle cx="540" cy="180" r="90" stroke="rgba(212,160,23,0.04)" stroke-width="0.5" fill="none"/>
    <circle cx="540" cy="180" r="130" stroke="rgba(212,160,23,0.025)" stroke-width="0.5" fill="none"/>
  </svg>
</div>

<div class="auth-wrap">
  <div class="auth-card">
    <div class="auth-eyebrow">§ Vectra Arch · Book Forge · Security</div>
    <div class="auth-title">Enable 2FA</div>
    <div class="auth-sub">vectraarch.live/forge · Link Your Authenticator</div>

    <div class="auth-warning">
      <div class="auth-warning-dot"></div>
      <span class="auth-warning-text">Security Setup · Keep This Key Private</span>
    </div>

    <div class="auth-qr-frame">
      <img src="<%= qr %>" alt="2FA QR Code"/>
    </div>

    <div class="auth-secret">
      <span class="auth-secret-label">Manual key — enter in your authenticator app</span>
      <%= secret %>
    </div>

    <% if (locals.error) { %>
    <div class="auth-error">⚠ <%= error %></div>
    <% } %>

    <form action="/forge/auth/2fa/setup" method="POST">
      <div class="auth-field">
        <label class="auth-label" for="token">Confirm Code</label>
        <input class="auth-input auth-input-code" id="token" name="token"
               type="text" placeholder="000000" maxlength="6"
               autocomplete="one-time-code" required autofocus/>
      </div>
      <button class="auth-submit" type="submit">Link Device ↗</button>
    </form>

    <a href="/forge/" class="auth-back">← Cancel</a>
  </div>
</div>
</body>
</html>
