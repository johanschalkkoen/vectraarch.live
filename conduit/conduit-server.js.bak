/**
 * Conduit Hub — VectraArch Automation, Social & Site Manager
 * Built on Express + express-session (same pattern as Book Forge)
 * so Foundation cross-domain auth works correctly.
 *
 * Port: 3100 (internal, nginx proxies)
 */

require('dotenv').config({ path: '/var/www/vectraarch.live/forge/.env' });
const pm2 = require('pm2');

const express        = require('express');
const session        = require('express-session');
const https          = require('https');
const fs             = require('fs');
const path           = require('path');
const { Pool }       = require('pg');
const { verify, generateSecret, generateURI } = require('otplib');
