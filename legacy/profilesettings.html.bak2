<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="apple-mobile-web-app-title" content="Legacy">
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
  <link rel="manifest" href="/manifest.json">
  <title>Profile Settings · Legacy · Vectra Arch</title>
  <script src="/legacy/auth-guard.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/react@18.2.0/umd/react.production.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/react-dom@18.2.0/umd/react-dom.production.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/@babel/standalone@7.20.6/babel.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/axios@1.4.0/dist/axios.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/compressorjs@1.2.1/dist/compressor.min.js"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Mono:ital,wght@0,300;0,400;0,500;1,300&family=Barlow:wght@300;400;500;600&family=Barlow+Condensed:wght@300;400;500;700;800&display=swap" rel="stylesheet"/>
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
    :root{
      --bg:#0a0a08;--bg2:#111110;--bg3:#191917;
      --border:rgba(255,255,255,0.07);--border2:rgba(255,255,255,0.14);
      --text:#e8e4d8;--text-muted:rgba(232,228,216,0.55);--text-dim:rgba(232,228,216,0.25);
      --accent:#00ff41;--accent2:#00b32c;--red:#b84040;--warn:#d4a800;
    }
    html{scroll-behavior:smooth;}
    body{background:var(--bg);color:var(--text);font-family:'Barlow',sans-serif;font-weight:300;font-size:16px;line-height:1.6;overflow-x:hidden;cursor:crosshair;min-height:100vh;}
    body::before{content:'';position:fixed;inset:0;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.035'/%3E%3C/svg%3E");opacity:0.4;pointer-events:none;z-index:0;}
    .grid-bg{position:fixed;inset:0;background-image:linear-gradient(var(--border) 1px,transparent 1px),linear-gradient(90deg,var(--border) 1px,transparent 1px);background-size:80px 80px;pointer-events:none;z-index:0;}
    .accent-lines{position:fixed;top:0;right:0;width:50%;height:100%;pointer-events:none;overflow:hidden;z-index:0;}
    .accent-lines svg{width:100%;height:100%;}
    nav{position:fixed;top:0;left:0;right:0;z-index:100;display:flex;align-items:center;justify-content:space-between;padding:0 40px;height:60px;border-bottom:1px solid var(--border);background:rgba(10,10,8,0.88);backdrop-filter:blur(12px);}
    .nav-logo{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:15px;letter-spacing:0.22em;text-transform:uppercase;color:var(--text);text-decoration:none;}
    .nav-logo span{color:var(--accent);}
    .nav-right{display:flex;align-items:center;gap:20px;}
    .nav-status{display:flex;align-items:center;gap:8px;font-family:'DM Mono',monospace;font-size:10px;color:var(--text-dim);letter-spacing:0.1em;}
    .nav-status::before{content:'';display:block;width:6px;height:6px;border-radius:50%;background:var(--accent);box-shadow:0 0 6px var(--accent);}
    #root{position:relative;z-index:1;}
    .profile-wrap{position:relative;z-index:1;max-width:900px;margin:0 auto;padding:88px 40px 80px;}
    .page-header{margin-bottom:40px;padding-bottom:24px;border-bottom:1px solid var(--border);}
    .page-eyebrow{font-family:'DM Mono',monospace;font-size:9px;letter-spacing:0.28em;text-transform:uppercase;color:var(--accent);margin-bottom:12px;}
    .page-title{font-family:'Bebas Neue',sans-serif;font-size:56px;line-height:0.9;color:var(--text);letter-spacing:0.02em;margin-bottom:4px;}
    .page-sub{font-family:'Barlow Condensed',sans-serif;font-weight:300;font-size:13px;letter-spacing:0.1em;text-transform:uppercase;color:var(--text-muted);}
    .user-header{display:flex;align-items:center;gap:20px;margin-bottom:36px;padding-bottom:28px;border-bottom:1px solid var(--border);}
    .user-avatar{width:56px;height:56px;border-radius:50%;object-fit:cover;object-position:center;border:1px solid var(--accent);flex-shrink:0;}
    .user-name{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:24px;letter-spacing:0.04em;text-transform:uppercase;color:var(--text);}
    .user-meta{font-family:'DM Mono',monospace;font-size:9px;letter-spacing:0.2em;text-transform:uppercase;color:var(--text-dim);margin-top:4px;}
    .alert{font-family:'DM Mono',monospace;font-size:10px;letter-spacing:0.1em;padding:12px 16px;border:1px solid;margin-bottom:24px;}
    .alert.ok{color:var(--accent);border-color:rgba(0,255,65,0.25);background:rgba(0,255,65,0.05);}
    .alert.err{color:var(--red);border-color:rgba(184,64,64,0.25);background:rgba(184,64,64,0.05);}
    .alert.warn{color:var(--warn);border-color:rgba(212,168,0,0.25);background:rgba(212,168,0,0.05);}
    .profile-section{background:var(--bg2);border:1px solid var(--border2);padding:32px;margin-bottom:1px;}
    .section-label{font-family:'DM Mono',monospace;font-size:9px;letter-spacing:0.25em;text-transform:uppercase;color:var(--accent);margin-bottom:24px;padding-bottom:10px;border-bottom:1px solid var(--border);}
    .form-grid{display:grid;grid-template-columns:1fr 1fr;gap:0 32px;}
    .mf-field{display:flex;flex-direction:column;gap:6px;margin-bottom:20px;}
    .mf-field.full{grid-column:1/-1;}
    .mf-label{font-family:'DM Mono',monospace;font-size:9px;letter-spacing:0.22em;text-transform:uppercase;color:var(--text-dim);}
    .mf-label .req{color:var(--red);}
    .mf-input,.mf-select,.mf-textarea{background:transparent;border:none;border-bottom:1px solid var(--border2);padding:10px 0;font-family:'DM Mono',monospace;font-size:13px;color:var(--text);outline:none;transition:border-color 0.2s;width:100%;}
    .mf-select{cursor:pointer;-webkit-appearance:none;background:var(--bg2);}
    .mf-select option{background:var(--bg2);color:var(--text);}
    .mf-input::placeholder,.mf-textarea::placeholder{color:var(--text-dim);}
    .mf-input:focus,.mf-select:focus,.mf-textarea:focus{border-bottom-color:var(--accent);}
    .mf-textarea{resize:vertical;min-height:80px;}
    .mf-input.err{border-bottom-color:var(--red);}
    .field-error{font-family:'DM Mono',monospace;font-size:9px;letter-spacing:0.1em;color:var(--red);margin-top:4px;}
    .mf-hint{font-family:'DM Mono',monospace;font-size:9px;letter-spacing:0.1em;color:var(--text-dim);margin-top:4px;}
    .mf-input[type="color"]{height:40px;padding:4px 0;cursor:crosshair;}
    .mf-input[type="file"]{padding:8px 0;font-size:11px;cursor:crosshair;}
    .va-btn{font-family:'DM Mono',monospace;font-size:10px;letter-spacing:0.16em;text-transform:uppercase;color:var(--text);background:none;border:1px solid var(--border2);padding:10px 20px;cursor:crosshair;transition:border-color 0.2s,color 0.2s;}
    .va-btn:hover{border-color:var(--accent);color:var(--accent);}
    .va-btn.primary{background:var(--accent);color:#0a0a08;border-color:var(--accent);}
    .va-btn.primary:hover{background:var(--accent2);border-color:var(--accent2);color:#fff;}
    .va-btn.danger{border-color:rgba(184,64,64,0.4);color:var(--red);}
    .va-btn.danger:hover{border-color:var(--red);background:rgba(184,64,64,0.06);}
    .va-btn.warn{border-color:rgba(212,168,0,0.4);color:var(--warn);}
    .va-btn.warn:hover{border-color:var(--warn);}
    .va-btn.full{width:100%;}
    .va-btn:disabled{opacity:0.3;cursor:not-allowed;}
    .btn-row{display:flex;gap:8px;margin-top:4px;flex-wrap:wrap;}
    .view-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px 40px;}
    .view-item{}
    .view-label{font-family:'DM Mono',monospace;font-size:9px;letter-spacing:0.2em;text-transform:uppercase;color:var(--text-dim);margin-bottom:4px;}
    .view-value{font-family:'Barlow Condensed',sans-serif;font-size:16px;letter-spacing:0.04em;color:var(--text-muted);}
    .view-value.empty{color:var(--text-dim);font-style:italic;}
    .color-swatch{width:28px;height:16px;display:inline-block;border:1px solid var(--border2);vertical-align:middle;margin-right:8px;}
    .notif-row{display:flex;align-items:center;justify-content:space-between;padding:14px 0;border-bottom:1px solid var(--border);}
    .notif-row:last-child{border-bottom:none;}
    .notif-label{font-family:'DM Mono',monospace;font-size:11px;letter-spacing:0.12em;color:var(--text-muted);}
    .toggle-pill{font-family:'DM Mono',monospace;font-size:9px;letter-spacing:0.14em;text-transform:uppercase;padding:5px 12px;border:1px solid;cursor:crosshair;transition:all 0.2s;}
    .toggle-pill.on{color:var(--accent);border-color:rgba(0,255,65,0.3);background:rgba(0,255,65,0.06);}
    .toggle-pill.off{color:var(--text-dim);border-color:var(--border2);background:transparent;}
    .toggle-pill:disabled{opacity:0.3;cursor:not-allowed;}
    .tx-table{width:100%;border-collapse:collapse;}
    .tx-table th{font-family:'DM Mono',monospace;font-size:9px;letter-spacing:0.18em;text-transform:uppercase;color:var(--text-dim);padding:10px 12px;text-align:left;border-bottom:1px solid var(--border2);}
    .tx-table td{padding:12px;border-bottom:1px solid var(--border);color:var(--text-muted);font-size:12px;font-family:'DM Mono',monospace;letter-spacing:0.06em;}
    .tx-table tr:last-child td{border-bottom:none;}
    .tx-table tr:hover td{background:var(--bg3);}
    .tx-empty{font-family:'DM Mono',monospace;font-size:10px;color:var(--text-dim);letter-spacing:0.1em;text-align:center;padding:24px;}
    .back-btn{font-family:'DM Mono',monospace;font-size:10px;letter-spacing:0.16em;text-transform:uppercase;color:var(--text-muted);background:none;border:1px solid var(--border2);padding:10px 20px;cursor:crosshair;transition:border-color 0.2s,color 0.2s;display:inline-flex;align-items:center;gap:8px;margin-bottom:32px;}
    .back-btn:hover{border-color:var(--text-dim);color:var(--text);}
    /* Identity link section */
    .identity-status{display:flex;align-items:center;gap:16px;padding:16px;background:var(--bg3);border:1px solid var(--border);margin-bottom:20px;}
    .identity-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0;}
    .identity-dot.linked{background:var(--accent);box-shadow:0 0 6px var(--accent);}
    .identity-dot.unlinked{background:var(--text-dim);}
    .identity-name{font-family:'Barlow Condensed',sans-serif;font-weight:600;font-size:15px;letter-spacing:0.06em;text-transform:uppercase;color:var(--text);}
    .identity-meta{font-family:'DM Mono',monospace;font-size:9px;letter-spacing:0.12em;color:var(--text-dim);margin-top:2px;}
    @media(max-width:768px){.form-grid,.view-grid{grid-template-columns:1fr;}nav{padding:0 20px;}.profile-wrap{padding:80px 20px 60px;}}
    @media(pointer:fine){body,a,button{cursor:crosshair;}}
  </style>
</head>
<body>
<div class="grid-bg"></div>
<div class="accent-lines" aria-hidden="true">
  <svg viewBox="0 0 600 900" fill="none" preserveAspectRatio="xMaxYMid slice">
    <line x1="580" y1="0" x2="20" y2="900" stroke="rgba(0,255,65,0.07)" stroke-width="1"/>
    <line x1="540" y1="0" x2="0" y2="760" stroke="rgba(0,255,65,0.05)" stroke-width="0.5"/>
    <line x1="600" y1="200" x2="100" y2="900" stroke="rgba(0,255,65,0.04)" stroke-width="1"/>
    <rect x="460" y="80" width="100" height="1" fill="rgba(0,255,65,0.15)"/>
    <rect x="480" y="120" width="60" height="1" fill="rgba(0,255,65,0.1)"/>
    <rect x="500" y="160" width="40" height="1" fill="rgba(0,255,65,0.07)"/>
    <circle cx="540" cy="180" r="60" stroke="rgba(0,255,65,0.04)" stroke-width="1" fill="none"/>
    <circle cx="540" cy="180" r="90" stroke="rgba(0,255,65,0.025)" stroke-width="0.5" fill="none"/>
    <circle cx="540" cy="180" r="130" stroke="rgba(0,255,65,0.015)" stroke-width="0.5" fill="none"/>
  </svg>
</div>

<nav>
  <a href="https://vectraarch.live" class="nav-logo">Vectra<span>&nbsp;</span>Arch</a>
  <div class="nav-right">
    <div class="nav-status">LEGACY · PROFILE</div>
  </div>
</nav>

<div id="root"></div>

<script type="text/babel">
  const { useState, useEffect, useCallback } = React;
  const API_BASE = '/legacy/api';
  // Identity calls go through the Legacy proxy (/legacy/api/identity/*)
  // The proxy injects the API key server-side — no key in the browser.
  const IDENTITY_BASE = '/api/identity';
  const getIdentityKey = () => ''; // key handled server-side by the proxy

  const DEFAULT_PROFILE_PIC = 'https://placehold.co/50x50/808080/FFFFFF?text=U';
  const DEFAULT_EVENT_COLOR = '#00ff41';

  const capitalize = str => str ? str.charAt(0).toUpperCase() + str.slice(1) : '';
  const formatDateTime = date => {
    if (!date) return '—';
    const d = new Date(date);
    if (isNaN(d.getTime())) return 'Invalid Date';
    return d.toLocaleString('en-ZA', { year:'numeric', month:'2-digit', day:'2-digit', hour:'2-digit', minute:'2-digit', hour12:false });
  };

  class ErrorBoundary extends React.Component {
    state = { error: null };
    static getDerivedStateFromError(error) { return { error: error.message }; }
    render() {
      if (this.state.error) return (
        <div className="profile-wrap">
          <div className="profile-section">
            <div className="alert err">⚠ {this.state.error}</div>
            <button className="va-btn" onClick={() => window.location.href = 'index.html'}>← Back to Login</button>
          </div>
        </div>
      );
      return this.props.children;
    }
  }

  // ── IDENTITY LINK SECTION ─────────────────────────────────────────────────
  const IdentitySection = ({ username }) => {
    const [link, setLink]           = useState(null);   // null = loading, false = not linked, object = linked
    const [loading, setLoading]     = useState(true);
    const [linking, setLinking]     = useState(false);
    const [unlinking, setUnlinking] = useState(false);
    const [showForm, setShowForm]   = useState(false);
    const [forgeId, setForgeId]     = useState('');
    const [msg, setMsg]             = useState({ text: '', type: '' });

    const apiKey = getIdentityKey();

    const fetchLink = useCallback(async () => {
      setLoading(true);
      try {
        const { data } = await axios.get(`${IDENTITY_BASE}/resolve`, {
          params: { legacy_username: username },
          headers: { 'X-API-Key': apiKey }
        });
        setLink(data.linked ? data.link : false);
      } catch {
        setLink(false);
      } finally {
        setLoading(false);
      }
    }, [username, apiKey]);

    useEffect(() => { fetchLink(); }, [fetchLink]);

    const handleLink = async () => {
      if (!forgeId.trim()) { setMsg({ text: 'Forge user ID required.', type: 'err' }); return; }
      setLinking(true);
      setMsg({ text: '', type: '' });
      try {
        const { data } = await axios.post(`${IDENTITY_BASE}/link`, {
          legacy_username: username,
          forge_user_id:   forgeId.trim(),
          linked_by:       username
        }, { headers: { 'X-API-Key': apiKey, 'Content-Type': 'application/json' } });

        if (data.success) {
          setMsg({ text: '✓ Identity linked successfully.', type: 'ok' });
          setShowForm(false);
          setForgeId('');
          await fetchLink();
        } else {
          setMsg({ text: data.message || 'Failed to link.', type: 'err' });
        }
      } catch (e) {
        setMsg({ text: e.response?.data?.message || 'Error linking identity.', type: 'err' });
      } finally {
        setLinking(false);
      }
    };

    const handleUnlink = async () => {
      if (!window.confirm('Unlink this identity? You can re-link at any time.')) return;
      setUnlinking(true);
      setMsg({ text: '', type: '' });
      try {
        const { data } = await axios.delete(`${IDENTITY_BASE}/link`, {
          data: { legacy_username: username, unlinked_by: username },
          headers: { 'X-API-Key': apiKey, 'Content-Type': 'application/json' }
        });
        if (data.success) {
          setMsg({ text: '✓ Identity unlinked.', type: 'ok' });
          setLink(false);
        } else {
          setMsg({ text: data.message || 'Failed to unlink.', type: 'err' });
        }
      } catch (e) {
        setMsg({ text: e.response?.data?.message || 'Error unlinking.', type: 'err' });
      } finally {
        setUnlinking(false);
      }
    };

    return (
      <div className="profile-section">
        <div className="section-label">§ 06 · Forge Identity Link</div>

        {msg.text && (
          <div className={`alert ${msg.type}`}>{msg.text}</div>
        )}

        {loading ? (
          <div style={{fontFamily:"'DM Mono',monospace",fontSize:'10px',color:'var(--text-dim)',letterSpacing:'0.1em'}}>§ Checking identity status...</div>
        ) : link ? (
          // ── LINKED STATE ──
          <div>
            <div className="identity-status">
              <div className="identity-dot linked"/>
              <div>
                <div className="identity-name">Linked to Book Forge</div>
                <div className="identity-meta">
                  Legacy: {link.legacy_username} · Forge: {link.forge_name || link.forge_user_id}
                </div>
                <div className="identity-meta" style={{marginTop:'2px'}}>
                  Linked {formatDateTime(link.linked_at)}{link.linked_by ? ` by ${link.linked_by}` : ''}
                </div>
              </div>
            </div>
            <div style={{fontFamily:"'DM Mono',monospace",fontSize:'9px',color:'var(--text-dim)',letterSpacing:'0.1em',marginBottom:'16px'}}>
              § Your Legacy account is linked to your Book Forge identity. Profile data syncs across both systems.
            </div>
            <button className="va-btn danger" onClick={handleUnlink} disabled={unlinking}>
              {unlinking ? 'Unlinking...' : 'Unlink Identity ×'}
            </button>
          </div>
        ) : (
          // ── UNLINKED STATE ──
          <div>
            <div className="identity-status">
              <div className="identity-dot unlinked"/>
              <div>
                <div className="identity-name" style={{color:'var(--text-muted)'}}>Not linked</div>
                <div className="identity-meta">This account has no Forge identity connection.</div>
              </div>
            </div>
            <div style={{fontFamily:"'DM Mono',monospace",fontSize:'9px',color:'var(--text-dim)',letterSpacing:'0.1em',marginBottom:'20px'}}>
              § Linking connects your Legacy account to your Book Forge identity, closing the identity boundary between systems.
            </div>

            {!showForm ? (
              <button className="va-btn primary" onClick={() => setShowForm(true)}>Link Forge Identity ↗</button>
            ) : (
              <div>
                <div className="mf-field" style={{maxWidth:'400px'}}>
                  <label className="mf-label">Forge User ID</label>
                  <input
                    className="mf-input"
                    placeholder="e.g. m_1778702898374 or Google ID"
                    value={forgeId}
                    onChange={e => setForgeId(e.target.value)}
                  />
                  <div className="mf-hint">
                    Find your Forge ID in Book Forge → your username is shown in the top-right corner.
                    Manual accounts are prefixed m_ — ask your admin if unsure.
                  </div>
                </div>
                <div className="btn-row">
                  <button className="va-btn primary" onClick={handleLink} disabled={linking}>
                    {linking ? 'Linking...' : 'Confirm Link ↗'}
                  </button>
                  <button className="va-btn" onClick={() => { setShowForm(false); setForgeId(''); setMsg({ text:'', type:'' }); }}>
                    Cancel
                  </button>
                </div>
              </div>
            )}
          </div>
        )}
      </div>
    );
  };

  // ── MAIN PROFILE COMPONENT ────────────────────────────────────────────────
  const ProfileSettings = ({ user, setPage, onLogout, setUser }) => {
    const [isEditing, setIsEditing] = useState(false);
    const [twoFAEnabled, setTwoFAEnabled] = useState(false);
    const [twoFASetup, setTwoFASetup] = useState({ qrCode: '', secret: '', token: '', step: 'idle' });
    const [twoFAMessage, setTwoFAMessage] = useState({ text: '', type: '' });
    const [disableToken, setDisableToken] = useState('');
    const [form, setForm] = useState({
      firstName: user.firstName || '',
      lastName: user.lastName || '',
      profilePicUrl: user.profilePicUrl || '',
      email: user.email || '',
      phone: user.phone || '',
      address: user.address || '',
      eventColor: user.eventColor || DEFAULT_EVENT_COLOR,
      gender: user.gender || '',
      telegram_chat_id: user.telegram_chat_id || '',
      displayName: user.displayName || user.username,
      bio: user.bio || '',
      pronouns: user.pronouns || '',
      theme: user.theme || 'dark',
      activityStatus: user.activityStatus || true,
      currentPassword: '',
      newPassword: '',
      confirmNewPassword: '',
      deletePassword: ''
    });
    const [selectedFile, setSelectedFile] = useState(null);
    const [message, setMessage] = useState({ text: '', type: '' });
    const [passwordMessage, setPasswordMessage] = useState({ text: '', type: '' });
    const [deleteMessage, setDeleteMessage] = useState({ text: '', type: '' });
    const [errors, setErrors] = useState({});
    const [notifications, setNotifications] = useState({ telegram: true, email: false });
    const [transactionHistory, setTransactionHistory] = useState([]);

    const msg = (text, type = 'ok') => setMessage({ text, type });
    const pwMsg = (text, type = 'ok') => setPasswordMessage({ text, type });
    const delMsg = (text, type = 'ok') => setDeleteMessage({ text, type });

    useEffect(() => {
      const fetchNotifications = async () => {
        try {
          const { data } = await axios.get(`${API_BASE}/notifications`, { params: { username: user.username } });
          if (data.success) {
            const notifs = {};
            data.notifications.forEach(n => { notifs[n.type] = !!n.enabled; });
            setNotifications({ telegram: true, email: false, ...notifs });
          }
        } catch {}
      };
      const fetchTransactions = async () => {
        try {
          const { data } = await axios.get(`${API_BASE}/transaction-history`, { params: { username: user.username } });
          if (data.success) setTransactionHistory(data.transactions);
        } catch {}
      };
      const check2FA = async () => {
        try {
          const r = await axios.get(`${API_BASE}/2fa/status?username=${user.username}`).catch(() => ({ data: { enabled: false } }));
          setTwoFAEnabled(r.data.enabled || false);
        } catch {}
      };
      fetchNotifications();
      fetchTransactions();
      check2FA();
    }, [user.username]);

    const fetchUserProfile = useCallback(async () => {
      try {
        const { data } = await axios.get(`${API_BASE}/profile-pictures`, { params: { username: user.username } });
        if (data.success) {
          const updated = { ...user, ...data, profilePicUrl: data.profilePicUrl || '', displayName: data.displayName || user.username };
          setUser(updated);
          localStorage.setItem('user', JSON.stringify(updated));
          setForm(prev => ({ ...prev, ...data, profilePicUrl: data.profilePicUrl || '', displayName: data.displayName || user.username }));
        }
      } catch {}
    }, [user.username, setUser]);

    const validate = () => {
      const e = {};
      if (!form.firstName) e.firstName = 'Required';
      if (!form.lastName) e.lastName = 'Required';
      if (form.firstName?.length > 50) e.firstName = 'Max 50 characters';
      if (form.lastName?.length > 50) e.lastName = 'Max 50 characters';
      if (form.bio?.length > 500) e.bio = 'Max 500 characters';
      if (form.pronouns?.length > 500) e.pronouns = 'Max 500 characters';
      if (form.telegram_chat_id && !/^-?\d+$/.test(form.telegram_chat_id)) e.telegram_chat_id = 'Must be a number (e.g. -123456789)';
      setErrors(e);
      return Object.keys(e).length === 0;
    };

    const handleChange = useCallback(e => {
      const { name, value, type, checked } = e.target;
      setForm(prev => ({ ...prev, [name]: type === 'checkbox' ? checked : value }));
    }, []);

    const cancelEdit = useCallback(() => {
      setIsEditing(false);
      setForm(prev => ({
        ...prev,
        firstName: user.firstName || '', lastName: user.lastName || '',
        profilePicUrl: user.profilePicUrl || '', email: user.email || '',
        phone: user.phone || '', address: user.address || '',
        eventColor: user.eventColor || DEFAULT_EVENT_COLOR, gender: user.gender || '',
        telegram_chat_id: user.telegram_chat_id || '', displayName: user.displayName || user.username,
        bio: user.bio || '', pronouns: user.pronouns || '',
        theme: user.theme || 'dark', activityStatus: user.activityStatus || true
      }));
      setErrors({});
      msg('', 'ok');
    }, [user]);

    const handleNotificationChange = useCallback(async (type, enabled) => {
      try {
        const { data } = await axios.post(`${API_BASE}/notifications`, { username: user.username, type, enabled });
        if (data.success) setNotifications(prev => ({ ...prev, [type]: enabled }));
      } catch {}
    }, [user.username]);

    const handleFileChange = useCallback(e => {
      const file = e.target.files[0];
      if (!file) return;
      if (!file.type.startsWith('image/')) { msg('Please select a valid image file.', 'err'); return; }
      if (file.size > 5 * 1024 * 1024) { msg('Image must be under 5MB.', 'err'); return; }
      new Compressor(file, {
        quality: 0.6, maxWidth: 500, maxHeight: 500,
        success(compressed) {
          setSelectedFile(compressed);
          const reader = new FileReader();
          reader.onloadend = () => setForm(prev => ({ ...prev, profilePicUrl: reader.result }));
          reader.readAsDataURL(compressed);
        },
        error() { msg('Image compression failed.', 'err'); }
      });
    }, []);

    const handleSaveProfile = useCallback(async () => {
      if (!validate()) return;
      msg('Saving...', 'warn');
      try {
        const urlToSave = selectedFile ? await new Promise((res, rej) => {
          const r = new FileReader();
          r.onloadend = () => res(r.result);
          r.onerror = rej;
          r.readAsDataURL(selectedFile);
        }) : form.profilePicUrl || DEFAULT_PROFILE_PIC;

        const { data } = await axios.post(`${API_BASE}/profile-pictures`, {
          username: user.username, firstName: form.firstName, lastName: form.lastName,
          profilePicUrl: urlToSave, email: form.email, phone: form.phone, address: form.address,
          eventColor: form.eventColor, gender: form.gender, telegram_chat_id: form.telegram_chat_id,
          displayName: form.displayName, bio: form.bio, pronouns: form.pronouns,
          theme: form.theme, activityStatus: form.activityStatus
        }, { headers: { 'Content-Type': 'application/json' } });

        if (data.success) {
          msg('Profile saved.', 'ok');
          await fetchUserProfile();
          setIsEditing(false);
        } else { msg(data.message || 'Failed to save.', 'err'); }
      } catch (err) { msg(err.response?.data?.message || 'Error saving profile.', 'err'); }
    }, [form, selectedFile, user.username, fetchUserProfile]);

    const handlePasswordChange = useCallback(async () => {
      pwMsg('', 'ok');
      if (!form.currentPassword || !form.newPassword || !form.confirmNewPassword) { pwMsg('All fields required.', 'err'); return; }
      if (form.newPassword !== form.confirmNewPassword) { pwMsg('Passwords do not match.', 'err'); return; }
      if (form.newPassword.length < 6) { pwMsg('Minimum 6 characters.', 'err'); return; }
      try {
        const { data } = await axios.post(`${API_BASE}/update-password`, {
          username: user.username, currentPassword: form.currentPassword, newPassword: form.newPassword
        });
        pwMsg(data.success ? 'Password updated.' : (data.message || 'Failed.'), data.success ? 'ok' : 'err');
        if (data.success) setForm(prev => ({ ...prev, currentPassword: '', newPassword: '', confirmNewPassword: '' }));
      } catch (err) { pwMsg(err.response?.data?.message || 'Error.', 'err'); }
    }, [form, user.username]);

    const handleDeleteAccount = useCallback(async () => {
      if (!form.deletePassword) { delMsg('Password required.', 'err'); return; }
      if (!window.confirm('Delete your account? This cannot be undone.')) return;
      try {
        const { data } = await axios.delete(`${API_BASE}/account`, { data: { username: user.username, password: form.deletePassword } });
        if (data.success) { delMsg('Account deleted.', 'ok'); onLogout(); }
        else { delMsg(data.message || 'Failed.', 'err'); }
      } catch (err) { delMsg(err.response?.data?.message || 'Error.', 'err'); }
    }, [form.deletePassword, user.username, onLogout]);

    const handle2FASetup = useCallback(async () => {
      setTwoFAMessage({ text: '', type: '' });
      try {
        const { data } = await axios.get(`${API_BASE}/2fa/setup?username=${user.username}`);
        if (data.success) {
          setTwoFASetup({ qrCode: data.qrCode, secret: data.secret, token: '', step: 'scan' });
        } else {
          setTwoFAMessage({ text: data.message || 'Failed to generate QR.', type: 'err' });
        }
      } catch (err) {
        setTwoFAMessage({ text: err.response?.data?.message || 'Error.', type: 'err' });
      }
    }, [user.username]);

    const confirm2FA = useCallback(async () => {
      if (!twoFASetup.token || twoFASetup.token.length !== 6) {
        setTwoFAMessage({ text: 'Enter the 6-digit code.', type: 'err' }); return;
      }
      try {
        const { data } = await axios.post(`${API_BASE}/2fa/setup`, {
          username: user.username, secret: twoFASetup.secret, token: twoFASetup.token
        });
        if (data.success) {
          setTwoFAEnabled(true);
          setTwoFASetup({ qrCode: '', secret: '', token: '', step: 'idle' });
          setTwoFAMessage({ text: '✓ 2FA enabled successfully.', type: 'ok' });
        } else {
          setTwoFAMessage({ text: data.message || 'Invalid code.', type: 'err' });
        }
      } catch (err) {
        setTwoFAMessage({ text: err.response?.data?.message || 'Error.', type: 'err' });
      }
    }, [twoFASetup, user.username]);

    const disable2FA = useCallback(async () => {
      if (!disableToken || disableToken.length !== 6) {
        setTwoFAMessage({ text: 'Enter the 6-digit code to disable 2FA.', type: 'err' }); return;
      }
      try {
        const { data } = await axios.post(`${API_BASE}/2fa/disable`, {
          username: user.username, token: disableToken
        });
        if (data.success) {
          setTwoFAEnabled(false);
          setDisableToken('');
          setTwoFAMessage({ text: '✓ 2FA disabled.', type: 'ok' });
        } else {
          setTwoFAMessage({ text: data.message || 'Invalid code.', type: 'err' });
        }
      } catch (err) {
        setTwoFAMessage({ text: err.response?.data?.message || 'Error.', type: 'err' });
      }
    }, [disableToken, user.username]);

    return (
      <div className="profile-wrap">
        <button className="back-btn" onClick={() => setPage('menu')}>← Back to Menu</button>

        <div className="page-header">
          <div className="page-eyebrow">§ Vectra Arch · Legacy · Identity</div>
          <div className="page-title">Profile</div>
          <div className="page-sub">Settings · Identity · Preferences</div>
        </div>

        <div className="user-header">
          <img className="user-avatar"
            src={form.profilePicUrl || DEFAULT_PROFILE_PIC}
            alt={form.displayName || user.username}
            style={{ borderColor: form.eventColor || DEFAULT_EVENT_COLOR }}/>
          <div>
            <div className="user-name">{form.displayName || user.username}</div>
            <div className="user-meta">§ {user.isAdmin ? 'Admin · ' : ''}{form.pronouns || 'Member'}</div>
          </div>
          <div style={{marginLeft:'auto'}}>
            {isEditing
              ? <div className="btn-row">
                  <button className="va-btn primary" onClick={handleSaveProfile}>Save ↗</button>
                  <button className="va-btn warn" onClick={cancelEdit}>Cancel</button>
                </div>
              : <button className="va-btn" onClick={() => setIsEditing(true)}>Edit Profile ↗</button>}
          </div>
        </div>

        {message.text && <div className={`alert ${message.type}`}>{message.type==='ok'?'✓ ':message.type==='err'?'⚠ ':'§ '}{message.text}</div>}

        {/* § 01 — Identity */}
        <div className="profile-section">
          <div className="section-label">§ 01 · Identity</div>
          {isEditing ? (
            <div className="form-grid">
              <div className="mf-field">
                <label className="mf-label">First Name <span className="req">*</span></label>
                <input className={`mf-input${errors.firstName?' err':''}`} name="firstName" placeholder="First name" value={form.firstName} onChange={handleChange}/>
                {errors.firstName && <div className="field-error">{errors.firstName}</div>}
              </div>
              <div className="mf-field">
                <label className="mf-label">Last Name <span className="req">*</span></label>
                <input className={`mf-input${errors.lastName?' err':''}`} name="lastName" placeholder="Last name" value={form.lastName} onChange={handleChange}/>
                {errors.lastName && <div className="field-error">{errors.lastName}</div>}
              </div>
              <div className="mf-field">
                <label className="mf-label">Display Name</label>
                <input className="mf-input" name="displayName" placeholder="Display name" value={form.displayName} onChange={handleChange}/>
              </div>
              <div className="mf-field">
                <label className="mf-label">Pronouns</label>
                <input className={`mf-input${errors.pronouns?' err':''}`} name="pronouns" placeholder="e.g. he/him" value={form.pronouns} onChange={handleChange}/>
                {errors.pronouns && <div className="field-error">{errors.pronouns}</div>}
              </div>
              <div className="mf-field full">
                <label className="mf-label">Bio</label>
                <textarea className={`mf-textarea${errors.bio?' err':''}`} name="bio" placeholder="A short bio..." rows="3" value={form.bio} onChange={handleChange}/>
                {errors.bio && <div className="field-error">{errors.bio}</div>}
              </div>
              <div className="mf-field">
                <label className="mf-label">Gender</label>
                <select className="mf-select" name="gender" value={form.gender} onChange={handleChange}>
                  <option value="">— Select —</option>
                  <option value="Male">Male</option>
                  <option value="Female">Female</option>
                </select>
              </div>
              <div className="mf-field">
                <label className="mf-label">Event Colour</label>
                <input className="mf-input" type="color" name="eventColor" value={form.eventColor} onChange={handleChange}/>
              </div>
            </div>
          ) : (
            <div className="view-grid">
              <div className="view-item"><div className="view-label">Name</div><div className={`view-value${!form.firstName&&!form.lastName?' empty':''}`}>{form.firstName||form.lastName ? `${form.firstName} ${form.lastName}`.trim() : 'Not set'}</div></div>
              <div className="view-item"><div className="view-label">Display Name</div><div className={`view-value${!form.displayName?' empty':''}`}>{form.displayName||'Not set'}</div></div>
              <div className="view-item"><div className="view-label">Pronouns</div><div className={`view-value${!form.pronouns?' empty':''}`}>{form.pronouns||'Not set'}</div></div>
              <div className="view-item"><div className="view-label">Gender</div><div className={`view-value${!form.gender?' empty':''}`}>{form.gender||'Not set'}</div></div>
              <div className="view-item" style={{gridColumn:'1/-1'}}><div className="view-label">Bio</div><div className={`view-value${!form.bio?' empty':''}`}>{form.bio||'Not set'}</div></div>
              <div className="view-item"><div className="view-label">Event Colour</div><div className="view-value"><span className="color-swatch" style={{background:form.eventColor||DEFAULT_EVENT_COLOR}}/>{form.eventColor||DEFAULT_EVENT_COLOR}</div></div>
            </div>
          )}
        </div>

        {/* § 02 — Contact */}
        <div className="profile-section">
          <div className="section-label">§ 02 · Contact & Location</div>
          {isEditing ? (
            <div className="form-grid">
              <div className="mf-field"><label className="mf-label">Email</label><input className="mf-input" type="email" name="email" placeholder="your@email.com" value={form.email} onChange={handleChange}/></div>
              <div className="mf-field"><label className="mf-label">Phone</label><input className="mf-input" type="tel" name="phone" placeholder="+27 00 000 0000" value={form.phone} onChange={handleChange}/></div>
              <div className="mf-field full"><label className="mf-label">Address</label><textarea className="mf-textarea" name="address" placeholder="Your address..." rows="2" value={form.address} onChange={handleChange}/></div>
            </div>
          ) : (
            <div className="view-grid">
              <div className="view-item"><div className="view-label">Email</div><div className={`view-value${!form.email?' empty':''}`}>{form.email||'Not set'}</div></div>
              <div className="view-item"><div className="view-label">Phone</div><div className={`view-value${!form.phone?' empty':''}`}>{form.phone||'Not set'}</div></div>
              <div className="view-item" style={{gridColumn:'1/-1'}}><div className="view-label">Address</div><div className={`view-value${!form.address?' empty':''}`}>{form.address||'Not set'}</div></div>
            </div>
          )}
        </div>

        {/* § 03 — Profile Picture */}
        <div className="profile-section">
          <div className="section-label">§ 03 · Profile Picture</div>
          <div style={{display:'flex',alignItems:'center',gap:'20px',marginBottom:'16px'}}>
            <img src={form.profilePicUrl||DEFAULT_PROFILE_PIC} alt="profile" style={{width:'56px',height:'56px',borderRadius:'50%',objectFit:'cover',border:`1px solid ${form.eventColor||DEFAULT_EVENT_COLOR}`}}/>
            <div>
              <div style={{fontFamily:"'DM Mono',monospace",fontSize:'10px',color:'var(--text-muted)',letterSpacing:'0.1em'}}>{form.displayName||user.username}</div>
              <div style={{fontFamily:"'DM Mono',monospace",fontSize:'9px',color:'var(--text-dim)',letterSpacing:'0.1em',marginTop:'4px'}}>Max 5MB · PNG / JPG</div>
            </div>
          </div>
          {isEditing && (
            <div className="mf-field">
              <label className="mf-label">Upload New Photo</label>
              <input className="mf-input" type="file" accept="image/*" onChange={handleFileChange}/>
            </div>
          )}
        </div>

        {/* § 04 — Telegram & Preferences */}
        <div className="profile-section">
          <div className="section-label">§ 04 · Telegram & Preferences</div>
          {isEditing ? (
            <div className="form-grid">
              <div className="mf-field">
                <label className="mf-label">Telegram Chat ID</label>
                <input className={`mf-input${errors.telegram_chat_id?' err':''}`} name="telegram_chat_id" placeholder="-123456789" value={form.telegram_chat_id} onChange={handleChange}/>
                {errors.telegram_chat_id ? <div className="field-error">{errors.telegram_chat_id}</div> : <div className="mf-hint">For personal Telegram notifications</div>}
              </div>
              <div className="mf-field">
                <label className="mf-label">Theme</label>
                <select className="mf-select" name="theme" value={form.theme} onChange={handleChange}>
                  <option value="dark">Dark</option>
                  <option value="light">Light</option>
                </select>
              </div>
              <div className="mf-field">
                <label className="mf-label" style={{display:'flex',alignItems:'center',gap:'8px',cursor:'crosshair'}}>
                  <input type="checkbox" name="activityStatus" checked={form.activityStatus} onChange={handleChange} style={{accentColor:'var(--accent)',cursor:'crosshair'}}/>
                  Show Activity Status
                </label>
              </div>
            </div>
          ) : (
            <div className="view-grid">
              <div className="view-item"><div className="view-label">Telegram Chat ID</div><div className={`view-value${!form.telegram_chat_id?' empty':''}`}>{form.telegram_chat_id||'Not set'}</div></div>
              <div className="view-item"><div className="view-label">Theme</div><div className="view-value">{capitalize(form.theme||'dark')}</div></div>
              <div className="view-item"><div className="view-label">Activity Status</div><div className="view-value">{form.activityStatus?'Visible':'Hidden'}</div></div>
            </div>
          )}
        </div>

        {/* § 05 — Notifications */}
        <div className="profile-section">
          <div className="section-label">§ 05 · Notification Preferences</div>
          <div className="notif-row">
            <span className="notif-label">Telegram Notifications</span>
            <button className={`toggle-pill ${notifications.telegram?'on':'off'}`} onClick={() => isEditing && handleNotificationChange('telegram', !notifications.telegram)} disabled={!isEditing}>{notifications.telegram?'On':'Off'}</button>
          </div>
          <div className="notif-row">
            <span className="notif-label">Email Notifications</span>
            <button className={`toggle-pill ${notifications.email?'on':'off'}`} onClick={() => isEditing && handleNotificationChange('email', !notifications.email)} disabled={!isEditing}>{notifications.email?'On':'Off'}</button>
          </div>
          {!isEditing && <div style={{fontFamily:"'DM Mono',monospace",fontSize:'9px',color:'var(--text-dim)',letterSpacing:'0.1em',marginTop:'12px'}}>§ Enter edit mode to change notification preferences</div>}
        </div>

        {/* § 06 — Forge Identity Link — NEW */}
        <IdentitySection username={user.username} />

        {/* § 07 — 2FA */}
        <div className="profile-section">
          <div className="section-label">§ 07 · Two-Factor Authentication</div>
          {twoFAMessage.text && <div className={`alert ${twoFAMessage.type}`}>{twoFAMessage.type==='ok'?'✓ ':'⚠ '}{twoFAMessage.text}</div>}
          <div style={{display:'flex',alignItems:'center',justifyContent:'space-between',marginBottom:'20px'}}>
            <div>
              <div style={{fontFamily:"'Barlow Condensed',sans-serif",fontWeight:600,fontSize:'16px',letterSpacing:'0.04em',textTransform:'uppercase',color:'var(--text)',marginBottom:'4px'}}>
                2FA: <span style={{color:twoFAEnabled?'var(--accent)':'var(--red)'}}>{twoFAEnabled?'Enabled':'Disabled'}</span>
              </div>
              <div style={{fontFamily:"'DM Mono',monospace",fontSize:'10px',color:'var(--text-dim)',letterSpacing:'0.08em'}}>
                {twoFAEnabled?'Your account is protected with two-factor authentication.':'Add an extra layer of security to your account.'}
              </div>
            </div>
            {!twoFAEnabled && twoFASetup.step==='idle' && (
              <button className="va-btn primary" onClick={handle2FASetup}>Enable 2FA ↗</button>
            )}
          </div>
          {twoFASetup.step==='scan' && (
            <div>
              <div style={{fontFamily:"'DM Mono',monospace",fontSize:'10px',color:'var(--text-muted)',letterSpacing:'0.08em',marginBottom:'16px'}}>§ Scan the QR code with your authenticator app (Google Authenticator, Authy, etc.)</div>
              {twoFASetup.qrCode && (
                <div style={{textAlign:'center',marginBottom:'16px',background:'white',padding:'16px',display:'inline-block'}}>
                  <img src={twoFASetup.qrCode} alt="QR Code" style={{width:'180px',height:'180px',display:'block'}}/>
                </div>
              )}
              <div style={{fontFamily:"'DM Mono',monospace",fontSize:'9px',color:'var(--text-dim)',letterSpacing:'0.12em',marginBottom:'20px'}}>
                Manual key: <span style={{color:'var(--accent)',letterSpacing:'0.2em'}}>{twoFASetup.secret}</span>
              </div>
              <div className="mf-field" style={{maxWidth:'240px'}}>
                <label className="mf-label">Confirm Code</label>
                <input className="mf-input" type="text" placeholder="000000" maxLength="6" value={twoFASetup.token} onChange={e=>setTwoFASetup(p=>({...p,token:e.target.value.replace(/[^0-9]/g,'')}))} style={{fontSize:'20px',letterSpacing:'0.3em',textAlign:'center'}}/>
              </div>
              <div style={{display:'flex',gap:'8px'}}>
                <button className="va-btn primary" onClick={confirm2FA}>Activate 2FA ↗</button>
                <button className="va-btn" onClick={()=>setTwoFASetup({qrCode:'',secret:'',token:'',step:'idle'})}>Cancel</button>
              </div>
            </div>
          )}
          {twoFAEnabled && (
            <div>
              <div style={{fontFamily:"'DM Mono',monospace",fontSize:'10px',color:'var(--text-dim)',letterSpacing:'0.08em',marginBottom:'16px'}}>§ Enter your current authenticator code to disable 2FA</div>
              <div className="mf-field" style={{maxWidth:'240px'}}>
                <label className="mf-label">Current Code</label>
                <input className="mf-input" type="text" placeholder="000000" maxLength="6" value={disableToken} onChange={e=>setDisableToken(e.target.value.replace(/[^0-9]/g,''))} style={{fontSize:'20px',letterSpacing:'0.3em',textAlign:'center'}}/>
              </div>
              <button className="va-btn danger" onClick={disable2FA}>Disable 2FA ×</button>
            </div>
          )}
        </div>

        {/* § 08 — Change Password */}
        <div className="profile-section">
          <div className="section-label">§ 08 · Change Password</div>
          {passwordMessage.text && <div className={`alert ${passwordMessage.type}`}>{passwordMessage.type==='ok'?'✓ ':'⚠ '}{passwordMessage.text}</div>}
          <div className="form-grid">
            <div className="mf-field"><label className="mf-label">Current Password</label><input className="mf-input" type="password" name="currentPassword" placeholder="········" value={form.currentPassword} onChange={handleChange}/></div>
            <div className="mf-field"></div>
            <div className="mf-field"><label className="mf-label">New Password</label><input className="mf-input" type="password" name="newPassword" placeholder="········" value={form.newPassword} onChange={handleChange}/></div>
            <div className="mf-field"><label className="mf-label">Confirm New Password</label><input className="mf-input" type="password" name="confirmNewPassword" placeholder="········" value={form.confirmNewPassword} onChange={handleChange}/></div>
          </div>
          <button className="va-btn primary" onClick={handlePasswordChange}>Change Password ↗</button>
        </div>

        {/* § 09 — Transaction History */}
        <div className="profile-section">
          <div className="section-label">§ 09 · Transaction History</div>
          {transactionHistory.length === 0
            ? <div className="tx-empty">No transactions recorded.</div>
            : <div style={{overflowX:'auto'}}>
                <table className="tx-table">
                  <thead><tr><th>Action</th><th>Table</th><th>Record</th><th>Modified By</th><th>Date</th></tr></thead>
                  <tbody>
                    {transactionHistory.map((tx, i) => (
                      <tr key={i}>
                        <td>{tx.action}</td>
                        <td>{tx.tableName}</td>
                        <td>{tx.recordId||'—'}</td>
                        <td>{tx.modifiedBy}</td>
                        <td>{formatDateTime(tx.modifiedAt)}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>}
        </div>

        {/* § 10 — Delete Account */}
        <div className="profile-section">
          <div className="section-label" style={{color:'var(--red)'}}>§ 10 · Delete Account</div>
          {deleteMessage.text && <div className={`alert ${deleteMessage.type}`}>{deleteMessage.type==='ok'?'✓ ':'⚠ '}{deleteMessage.text}</div>}
          <div style={{fontFamily:"'DM Mono',monospace",fontSize:'10px',color:'var(--text-dim)',letterSpacing:'0.1em',marginBottom:'20px'}}>§ This action is permanent and cannot be undone. All data will be deleted.</div>
          <div className="mf-field" style={{maxWidth:'360px'}}>
            <label className="mf-label">Confirm Password</label>
            <input className="mf-input" type="password" name="deletePassword" placeholder="········" value={form.deletePassword} onChange={handleChange}/>
          </div>
          <button className="va-btn danger" onClick={handleDeleteAccount}>Delete Account ×</button>
        </div>

        <div style={{marginTop:'32px',display:'flex',justifyContent:'space-between',alignItems:'center'}}>
          <button className="back-btn" onClick={() => setPage('menu')}>← Back to Menu</button>
          <button className="va-btn danger" onClick={onLogout}>Sign Out ×</button>
        </div>
      </div>
    );
  };

  const App = () => {
    const [user, setUser] = useState(null);
    const [error, setError] = useState('');

    useEffect(() => {
      const stored = localStorage.getItem('user');
      if (stored) {
        try { setUser(JSON.parse(stored)); }
        catch { setError('Invalid session. Please log in again.'); }
      } else { setError('Please log in to access your profile.'); }
    }, []);

    const handleLogout = useCallback(() => { localStorage.removeItem('user'); window.location.href = 'index.html'; }, []);

    if (error) return (
      <div className="profile-wrap"><div className="profile-section"><div className="alert err">⚠ {error}</div><button className="va-btn" onClick={() => window.location.href = 'index.html'}>← Go to Login</button></div></div>
    );
    if (!user) return (
      <div className="profile-wrap"><div className="profile-section"><div style={{fontFamily:"'DM Mono',monospace",fontSize:'10px',color:'var(--text-dim)',letterSpacing:'0.1em'}}>§ Loading...</div></div></div>
    );

    return (
      <ErrorBoundary>
        <ProfileSettings user={user} setPage={() => window.location.href = 'index.html'} onLogout={handleLogout} setUser={setUser}/>
      </ErrorBoundary>
    );
  };

  try { ReactDOM.render(<App/>, document.getElementById('root')); }
  catch (err) {
    document.getElementById('root').innerHTML =
      `<div class="profile-wrap"><div class="profile-section"><div class="alert err">⚠ Render error: ${err.message}</div></div></div>`;
  }
</script>
</body>
</html>
